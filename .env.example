# ─────────────────────────────────────────────────────────────────────────────
# NitiAI — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (required)
# Vercel: Add a Vercel Postgres DB or use Neon / Supabase
DATABASE_URL=postgresql://user:password@host:5432/nitiai

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-google-gemini-api-key-here

# ── Session ───────────────────────────────────────────────────────────────────
# Random secret used for signing session tokens (generate with: openssl rand -hex 32)
SESSION_SECRET=change-me-to-a-random-32-char-string

# ── Server (set automatically by Vercel) ────────────────────────────────────
# PORT=8080
